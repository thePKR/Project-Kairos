# ============================================
# Project Kairos — Environment Configuration
# ============================================
# Copy this file to `.env` and fill in your keys.
# Only NVIDIA_API_KEY is required. Everything else is optional.

# ── Required ──────────────────────────────────
# Get a free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# ── Optional LLM Providers ───────────────────
# DeepSeek — used for systems engineering tasks
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GPT-OSS — used for core reasoning
GPT_OSS_API_KEY=your_gpt_oss_api_key_here
GPT_OSS_BASE_URL=http://localhost:8000/v1

# Kimi (Moonshot) — used for swarm visualization
KIMI_API_KEY=your_kimi_api_key_here

# ── Neo4j AuraDB (Long-Term Graph Memory) ────
# Get a free instance at https://neo4j.com/cloud/aura-free/
NEO4J_URI=neo4j+s://your_instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── LangSmith Tracing (Debugging) ────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=ProjectKairos
